# ════════════════════════════════════════════════════════════════════════════
# AI Action Assistant — Environment Variables
# Copy this file to .env and fill in your values.
# ════════════════════════════════════════════════════════════════════════════

# ─── LLM (Groq) — 3-Tier API Key Architecture ────────────────────────────────
#
# Get free API keys at: https://console.groq.com
# Create 3 separate Groq accounts for maximum combined token budget.
#
# TIER 1 — PRIMARY  (intent detection, RAG, confirmation, missing field prompts)
# Model : openai/gpt-oss-120b  |  Best reasoning quality
GROQ_API_KEY_PRIMARY=your_primary_groq_api_key
GROQ_MODEL_PRIMARY=openai/gpt-oss-120b

# TIER 2 — MEDIUM   (email drafting, summarization, calendar descriptions)
# Model : llama-3.3-70b-versatile  |  Good writing + large context  |  100k TPD free
GROQ_API_KEY_MEDIUM=your_medium_groq_api_key
GROQ_MODEL_MEDIUM=llama-3.3-70b-versatile

# TIER 3 — LIGHT    (weather, news, search formatting, general fallback)
# Model : llama-3.1-8b-instant  |  Ultra-fast  |  500k TPD free
GROQ_API_KEY_LIGHT=your_light_groq_api_key
GROQ_MODEL_LIGHT=llama-3.1-8b-instant

# Single key setup — if you only have ONE Groq key, uncomment and set this.
# All tiers will use it automatically. No other changes needed.
# GROQ_API_KEY=your_single_groq_api_key
# GROQ_MODEL=openai/gpt-oss-120b

LLM_PROVIDER=groq

# ─── Vector Database ──────────────────────────────────────────────────────────
# Local: ./chroma_db  |  Railway: /app/chroma_db (auto-detected)
CHROMA_DB_DIR=./chroma_db

# ─── File Uploads ─────────────────────────────────────────────────────────────
# Local: ./uploads  |  Railway: /tmp/uploads (auto-detected)
UPLOAD_DIR=./uploads

# ─── Email (Gmail API via OAuth2) ─────────────────────────────────────────────
# Your Gmail address used as the From: header when sending via Gmail API.
# No SMTP, no app password. Auth is handled by credentials.json + token.pickle.
EMAIL_USER=your_gmail@gmail.com

# ─── Voice — STT: Groq Whisper ────────────────────────────────────────────────
# Uses GROQ_API_KEY_PRIMARY above — no extra key needed.
WHISPER_MODEL=whisper-large-v3-turbo
WHISPER_LANGUAGE=en
GROQ_AUDIO_URL=https://api.groq.com/openai/v1/audio/transcriptions


# ─── News API ─────────────────────────────────────────────────────────────────
# Free at: https://newsapi.org
NEWS_API_KEY=your_newsapi_key

# ─── Weather API ──────────────────────────────────────────────────────────────
# Free at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_key

# ─── Google Calendar + Gmail OAuth2 ───────────────────────────────────────────
# Run: python scripts/calendar_auth.py to generate token.pickle
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.pickle
CALENDAR_TIMEZONE=Asia/Kolkata

# ─── RAG Settings ─────────────────────────────────────────────────────────────
SIMILARITY_THRESHOLD=0.45
DEFAULT_URLS=https://en.wikipedia.org/wiki/Srinivasa_Ramanujan,https://en.wikipedia.org/wiki/India

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60

# ─── File Upload Limits ───────────────────────────────────────────────────────
UPLOAD_MAX_BYTES=10485760
UPLOAD_MAX_AGE_SECONDS=3600

# ─── Auth (JWT) ───────────────────────────────────────────────────────────────
# Auto-generated at startup if not set. Set explicitly in production.
# JWT_SECRET_KEY=your_secret_key_here
JWT_EXPIRE_HOURS=72

# ─── Database ─────────────────────────────────────────────────────────────────
# Leave blank for SQLite (local dev). Set PostgreSQL URL for Railway.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Defaults to localhost ports.
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ─── Session Store ────────────────────────────────────────────────────────────
# Optional Redis for persistent sessions across restarts (Railway Redis plugin).
# REDIS_URL=redis://localhost:6379

# ─── Railway Only — base64-encoded Google auth files ──────────────────────────
# Run: python scripts/encode_token.py  →  paste output as GOOGLE_TOKEN_B64
# Run: python -c "import base64; print(base64.b64encode(open('credentials.json','rb').read()).decode())"  →  GOOGLE_CREDENTIALS_B64
# GOOGLE_TOKEN_B64=
# GOOGLE_CREDENTIALS_B64=